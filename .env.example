# Docker PostgreSQL bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drivee_nl2sql
DB_CONTAINER_NAME=drivee_nl2sql_db
PGHOST_PORT=15432
READONLY_DB_USER=readonly_user
READONLY_DB_PASSWORD=change_me_for_local_dev
SQL_STATEMENT_TIMEOUT_MS=15000
SQL_MAX_TOTAL_COST=100000
SQL_RESULT_MAX_ROWS=200
# Only for local debugging when readonly credentials are intentionally unavailable.
ALLOW_RUNTIME_DB_ADMIN_FALLBACK=0

# Script/runtime DB connection (used by scripts/init_db.py and scripts/init_vanna.py)
PGHOST=127.0.0.1
PGPORT=15432
PGDATABASE=drivee_nl2sql
PGUSER=postgres
PGPASSWORD=postgres

# LLM runtime (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=

# OpenRouter shortcut (если используете OpenRouter вместо OPENAI_API_KEY)
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Drivee NL2SQL
